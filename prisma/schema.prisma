// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Voxelo-internal staff roles ─────────────────────────────────────────────
enum VoxeloStaffRole {
  SUPER_ADMIN
  AGENT
}

// ─── Commission lifecycle ─────────────────────────────────────────────────────
enum CommissionStatus {
  PENDING
  APPROVED
  PAID
}

enum VoiceVariant {
  SYSTEM
  CUSTOM
}

enum VoiceCategory {
  AUDIOBOOK
  CONVERSATIONAL
  CUSTOMER_SERVICE
  GENERAL
  NARRATIVE
  CHARACTERS
  MEDITATION
  MOTIVATIONAL
  PODCAST
  ADVERTISING
  VOICEOVER
  CORPORATE
}

model Voice {
  id String @id @default(cuid())

  orgId String?

  name        String
  description String?
  category    VoiceCategory @default(GENERAL)
  language    String        @default("en-US")
  variant     VoiceVariant
  r2ObjectKey String?

  generations Generation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([variant])
  @@index([orgId])
}

model Generation {
  id String @id @default(cuid())

  orgId String

  voiceId String?
  voice   Voice?  @relation(fields: [voiceId], references: [id], onDelete: SetNull)

  text              String
  voiceName         String
  r2ObjectKey       String?
  temperature       Float
  topP              Float
  topK              Int
  repetitionPenalty Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([voiceId])
}

model Tenant {
  id            String   @id @default(cuid())
  clerkOrgId    String?  @unique  // Clerk Organization ID (null for demo/seeded tenant)
  name          String
  phoneNumber   String   @unique  // Twilio number (use "pending-<id>" until provisioned)
  greeting      String   @default("Hello, thank you for calling.")
  businessHours Json?    // {mon: {open: "08:00", close: "17:00"}, ...}
  voiceId       String   @default("21m00Tcm4TlvDq8ikWAM")
  faqContent    String?  @db.Text
  ownerEmail    String
  createdAt     DateTime @default(now())

  users           User[]
  calls           Call[]
  messages        Message[]
  appointments    Appointment[]
  knowledgeBases  KnowledgeBase[]
  settings        Setting[]
  attribution     TenantAttribution?
  payfastPayments PayFastPayment[]

  @@index([clerkOrgId])
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  tenantId    String
  role        String   @default("member") // owner, admin, member
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([clerkUserId])
}

model Call {
  id           String   @id @default(cuid())
  tenantId     String
  callerPhone  String
  callerName   String?
  intent       String?  // booking, message, faq, emergency, etc.
  transcript   Json?    // array of {role, text, timestamp}
  duration     Int?     // seconds
  recordingUrl String?
  status       String   @default("active") // active, completed, transferred
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model Message {
  id          String   @id @default(cuid())
  tenantId    String
  callerName  String
  callerPhone String
  message     String   @db.Text
  delivered   Boolean  @default(false)
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, delivered])
}

model Appointment {
  id          String   @id @default(cuid())
  tenantId    String
  callerName  String
  callerPhone String
  startTime   DateTime
  duration    Int      @default(30) // minutes
  notes       String?
  status      String   @default("confirmed")
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, startTime])
}

model KnowledgeBase {
  id       String @id @default(cuid())
  tenantId String
  title    String
  content  String @db.Text
  type     String @default("faq") // faq, procedure, policy, product

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Setting {
  id       String @id @default(cuid())
  tenantId String
  key      String
  value    String @db.Text

  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// VOXELO INTERNAL — staff, commissions, billing
// ─────────────────────────────────────────────────────────────────────────────

// Voxelo employees: super admins and sales agents
model VoxeloStaff {
  id                String          @id @default(cuid())
  clerkUserId       String          @unique
  name              String
  email             String          @unique
  role              VoxeloStaffRole @default(AGENT)
  isActive          Boolean         @default(true)
  // Salary in ZAR — 0 means commission-only
  fixedSalary       Decimal         @default(0)    @db.Decimal(10, 2)
  // Per-agent commission rate override (e.g. 0.15 = 15%)
  commissionRate    Decimal         @default(0.15) @db.Decimal(5, 4)
  commissionEnabled Boolean         @default(true)
  // Unique code used in referral URLs: /ref/<code>
  referralCode      String          @unique

  attributions TenantAttribution[]
  commissions  Commission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkUserId])
  @@index([referralCode])
}

// Links a tenant to the agent who referred / signed them up
model TenantAttribution {
  id           String   @id @default(cuid())
  tenantId     String   @unique    // one agent per tenant
  agentId      String
  referralCode String?             // populated when attributed via link
  createdAt    DateTime @default(now())

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent  VoxeloStaff @relation(fields: [agentId],  references: [id], onDelete: Restrict)

  @@index([agentId])
}

// Raw PayFast payment events received from their webhook
model PayFastPayment {
  id            String   @id @default(cuid())
  tenantId      String?
  pfPaymentId   String   @unique
  amount        Decimal  @db.Decimal(10, 2)
  itemName      String?
  paymentStatus String   // COMPLETE | CANCELLED | FAILED
  billingDate   DateTime
  rawPayload    Json
  createdAt     DateTime @default(now())

  tenant      Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  commissions Commission[]

  @@index([tenantId])
  @@index([billingDate])
}

// One commission record per agent per PayFast payment
model Commission {
  id               String           @id @default(cuid())
  agentId          String
  tenantId         String
  paymentId        String
  grossAmount      Decimal          @db.Decimal(10, 2)
  // Snapshot of the rate at calculation time — rate changes don't affect past records
  commissionRate   Decimal          @db.Decimal(5, 4)
  commissionAmount Decimal          @db.Decimal(10, 2)
  // First day of the month this commission belongs to — used for grouping
  month            DateTime
  status           CommissionStatus @default(PENDING)
  paidAt           DateTime?
  notes            String?          @db.Text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  agent   VoxeloStaff    @relation(fields: [agentId],   references: [id], onDelete: Restrict)
  payment PayFastPayment @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@unique([agentId, paymentId])  // prevent double-counting the same payment
  @@index([agentId])
  @@index([agentId, month])
  @@index([status])
  @@index([month])
}

// Global Voxelo platform settings — singleton row with id = "global"
model VoxeloSettings {
  id                    String   @id @default("global")
  // Fallback rate used when an agent has no individual override
  defaultCommissionRate Decimal  @default(0.15) @db.Decimal(5, 4)
  updatedAt             DateTime @updatedAt
}
